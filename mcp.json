{
  "version": "1.0",
  "name": "agentic-senior-core",
  "description": "MCP configuration for governance-aware diagnostics and self-healing workflows with dynamic knowledge injection.",
  "knowledgeLayers": {
    "enabled": true,
    "description": "8-layer dynamic knowledge injection for AI agents",
    "layers": {
      "rules": {
        "path": ".agent-context/rules",
        "count": 14,
        "autoLoad": true
      },
      "stack-strategies": {
        "path": "dynamic",
        "count": 0,
        "autoLoad": true
      },
      "architecture-playbooks": {
        "path": "dynamic",
        "count": 0,
        "autoLoad": true
      },
      "execution-contracts": {
        "path": "dynamic",
        "count": 0,
        "autoLoad": true,
        "sources": ["prompts", "review-checklists", "policies"]
      },
      "prompts": {
        "path": ".agent-context/prompts",
        "count": 3,
        "autoLoad": true,
        "templates": ["init-project", "refactor", "review-code"]
      },
      "governance-modes": {
        "path": "dynamic",
        "count": 0,
        "autoLoad": true,
        "governance": ["platform", "regulated", "startup"]
      },
      "state": {
        "path": ".agent-context/state",
        "count": 6,
        "autoLoad": true
      },
      "policies": {
        "path": ".agent-context/policies",
        "count": 1,
        "autoLoad": true
      }
    }
  },
  "servers": {
    "lint": {
      "command": "node",
      "args": ["./scripts/validate.mjs"],
      "transport": "stdio"
    },
    "test": {
      "command": "node",
      "args": ["--test", "./tests/cli-smoke.test.mjs", "./tests/llm-judge.test.mjs"],
      "transport": "stdio"
    }
  },
  "workflows": {
    "self-heal-on-failure": {
      "trigger": ["ci.failure", "lint.failure"],
      "steps": [
        "collect_logs",
        "map_violation_to_rule",
        "propose_patch",
        "run_checklist_review"
      ]
    },
    "full-knowledge-injection": {
      "trigger": ["workspace.initialize", "agent.start"],
      "steps": [
        "load_all_knowledge_layers",
        "inject_rules",
        "inject_stack_strategies",
        "inject_architecture_playbooks",
        "inject_execution_contracts",
        "inject_prompts",
        "inject_governance_modes",
        "inject_state",
        "inject_policies"
      ]
    }
  }
}
